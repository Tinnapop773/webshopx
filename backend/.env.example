# MongoDB
MONGODB_URI=mongodb://localhost:27017/webshopx

# JWT
JWT_SECRET=your_jwt_secret_key_here
JWT_EXPIRE=7d

# Admin PIN
ADMIN_PIN=1234

# Bank API Integration
BANK_API_URL=https://api.rdcw.com
BANK_API_KEY=your_bank_api_key
BANK_MERCHANT_ID=your_merchant_id

# True Wallet Integration
TRUE_WALLET_API_URL=https://api.truewallet.com
TRUE_WALLET_API_KEY=your_truewallet_api_key

# Discord Webhook
DISCORD_WEBHOOK_URL=https://discord.com/api/webhooks/xxx/yyy

# Server
PORT=5000
NODE_ENV=development
CLIENT_URL=http://localhost:3000

# Site Configuration
SITE_NAME=WebShopX
SITE_PRIMARY_COLOR=#3498db
SITE_SECONDARY_COLOR=#2ecc71
